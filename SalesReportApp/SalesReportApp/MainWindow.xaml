<Window x:Class="SalesReportApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отдел продаж — Главное меню" Height="520" Width="420"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Тип устройства -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <Label Content="Тип устройства:" FontWeight="Bold"/>
            <ComboBox x:Name="cbDeviceType" Height="28"/>
        </StackPanel>

        <!-- Период -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <Label Content="Период отчёта:" FontWeight="Bold"/>
            <ComboBox x:Name="cbPeriod" Height="28"
                      SelectionChanged="cbPeriod_SelectionChanged"/>
        </StackPanel>

        <!-- Дата -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Label Content="Выберите дату:" FontWeight="Bold"/>
            <DatePicker x:Name="dpDate" Height="28"
                        SelectedDateChanged="dpDate_SelectedDateChanged"/>
        </StackPanel>

        <!-- Список отчётов -->
        <StackPanel Grid.Row="3" Margin="0,0,0,4">
            <Label Content="Доступные отчёты:" FontWeight="Bold"/>
        </StackPanel>
        <ListBox Grid.Row="4" x:Name="lbReports" Margin="0,0,0,10"
                 SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding DisplayName}"
                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              Checked="CheckBox_Changed"
                              Unchecked="CheckBox_Changed"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Формат файлов -->
        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <Label Content="Формат хранения файлов:" FontWeight="Bold"/>
            <ComboBox x:Name="cbFormat" Height="28"
                      SelectionChanged="cbFormat_SelectionChanged"/>
        </StackPanel>

        <!-- Кнопка -->
        <Button Grid.Row="6" x:Name="btnShowReport"
                Content="Показать отчёт" Height="36"
                IsEnabled="False"
                Click="btnShowReport_Click"
                FontSize="14"/>
    </Grid>
</Window>
