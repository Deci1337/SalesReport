<Window x:Class="SalesReportApp.PriceChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="420" Width="620"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" x:Name="lblTitle" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
            <Canvas x:Name="chartCanvas" Background="White"
                    SizeChanged="chartCanvas_SizeChanged"/>
        </Border>
    </Grid>
</Window>
