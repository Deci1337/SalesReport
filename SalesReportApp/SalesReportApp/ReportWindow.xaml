<Window x:Class="SalesReportApp.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт по продажам" Height="560" Width="780">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кнопки сортировки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Сортировка:" VerticalAlignment="Center"/>
            <Button x:Name="btnSortAsc" Content="↑ По артикулу"
                    Width="130" Height="28" Margin="4,0"
                    Click="btnSortAsc_Click"/>
            <Button x:Name="btnSortDesc" Content="↓ По артикулу"
                    Width="130" Height="28" Margin="4,0"
                    Click="btnSortDesc_Click"/>
        </StackPanel>

        <!-- Таблица -->
        <DataGrid Grid.Row="1" x:Name="dgProducts"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул"      Binding="{Binding Article}"   Width="80"/>
                <DataGridTextColumn Header="Бренд"        Binding="{Binding Brand}"     Width="90"/>
                <DataGridTextColumn Header="Модель"       Binding="{Binding ModelName}" Width="150"/>
                <DataGridTextColumn Header="Тип"          Binding="{Binding TypeName}"  Width="90"/>
                <DataGridTextColumn Header="Цена (руб.)"  Binding="{Binding Price}"     Width="100"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding SaleDate}"  Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Динамика цены -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Артикул для графика:" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbArticle" Width="120" Height="28" Margin="4,0"
                      SelectionChanged="cbArticle_SelectionChanged"/>
            <Button x:Name="btnPriceChart" Content="Динамика цены"
                    Width="130" Height="28" Margin="4,0"
                    IsEnabled="False"
                    Click="btnPriceChart_Click"/>
        </StackPanel>

        <!-- Сохранить -->
        <Button Grid.Row="3" x:Name="btnSave"
                Content="Сохранить отчёт в файл"
                Height="34" FontSize="13"
                Click="btnSave_Click"/>
    </Grid>
</Window>
